# Copiar a .env.local y completar valores.

# URL pública del sitio (OG / metadata). Producción ej.: https://frontendacademy.miralab.ar
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Obligatorio en producción (firma JWT / sesión)
AUTH_SECRET=

# MongoDB: si está vacío, usuarios y progreso usan JSON bajo data/
MONGODB_URI=
MONGODB_DB=
MONGODB_USERS_COLLECTION=
MONGODB_PROGRESS_COLLECTION=
MONGODB_USERNAME_FIELD=
MONGODB_PASSWORD_FIELD=
MONGODB_CREATED_AT_FIELD=

# Rate limit distribuido para POST /api/exercises/run (opcional)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
EXERCISE_RUN_RATE_LIMIT_PER_MIN=
