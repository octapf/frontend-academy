# Copiá a `.env.local` (no se commitea).

# Firma de sesión JWT (32+ caracteres aleatorios). Requerido en producción.
AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# --- Auth: MongoDB (opcional) ---
# Si está definido, login/registro leen y escriben usuarios en MongoDB.
# Si no, se usa `data/users.json` (modo archivo, útil sin Atlas).
MONGODB_URI=

# Base de datos (opcional si ya va en la URI, p.ej. ...mongodb.net/fea).
MONGODB_DB=

# Colección de usuarios (default: users)
MONGODB_USERS_COLLECTION=users

# Si tus documentos ya existentes usan otros nombres de campo:
# MONGODB_USERNAME_FIELD=username
# MONGODB_PASSWORD_FIELD=passwordHash
# MONGODB_CREATED_AT_FIELD=createdAt

# Recomendado en Atlas: índice único en el campo de login, p.ej.
# db.users.createIndex({ username: 1 }, { unique: true })

# --- Progreso (Mongo, misma URI que usuarios) ---
# Colección por usuario (documento con lessons + exercises). Default: user_progress
# MONGODB_PROGRESS_COLLECTION=user_progress
# db.user_progress.createIndex({ username: 1 }, { unique: true })

# --- Rate limit ejercicios TS (por usuario, ventana 1 min) ---
# EXERCISE_RUN_RATE_LIMIT_PER_MIN=40
#
# Opcional: Upstash Redis (mismo límite en todas las instancias / serverless).
# https://upstash.com — crear DB Redis y pegar REST URL + token.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
#
# Migrar progreso local → Mongo (requiere MONGODB_URI y data/progress.json):
# npm run migrate:progress
